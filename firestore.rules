rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /slots/{slotId} {
      allow get: if true;
      // Cost-abuse guard: anonymous list queries must carry an explicit limit
      // so a single request can never bill the whole collection. Every shipped
      // client query uses limit <= 120 (see src/lib/slots.ts); admins keep
      // unbounded lists for wipe/reseed/fee tooling. A query with no limit
      // fails the null check and is denied.
      allow list: if (request.query.limit != null && request.query.limit <= 150) || isAdmin();
      allow write: if isAdmin();
    }

    // public/ and config/ hold well-known single docs (tokenStats, liveStream,
    // vodPlaylist, emergencyOverride, scheduleMeta, ticker) — clients only ever
    // read them by ID, so collection listing stays off.
    match /public/{docId} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }

    // config/ticker feeds the OBS broadcast ticker overlay
    // (docs/obs/csgn-ticker.html), which polls it unauthenticated over the
    // public Firestore REST API — read is deliberately fully public. Writes
    // (Admin panel headline rail + coin spotlight) stay admin-only.
    match /config/ticker {
      allow read: if true;
      allow write: if isAdmin();
    }

    // votes/{voteId} holds the aggregate tally (tokens + distinct-wallet count
    // per option), updated atomically by the castVote function (firebase-admin,
    // which bypasses these rules). Public read powers the scoreboard and the
    // on-air overlay; admins create/reset a vote from the panel. Individual
    // ballots (votes/{id}/ballots/{wallet}) have no rule → server-only.
    match /votes/{voteId} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /uniqueEmails/{docId} { allow read, write: if isAdmin(); }
    match /uniqueUsernames/{docId} { allow read, write: if isAdmin(); }
    match /uniquePhantomWallets/{docId} { allow read, write: if isAdmin(); }
    match /uniqueTwitchUsers/{docId} { allow read, write: if isAdmin(); }
    match /oauthStates/{docId} { allow read, write: if isAdmin(); }
    match /twitchOAuthResults/{docId} { allow read, write: if false; }
    match /phantomChallenges/{docId} { allow read, write: if isAdmin(); }
    match /auditLogs/{docId} { allow read, write: if isAdmin(); }

    match /applications/{appId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /auth_events/{eventId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
