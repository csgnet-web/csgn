# Solscan Pro API key (server-only) — powers Live Earnings. Set in Netlify env,
# never commit the real value. Create at https://solscan.io (free tier available).
SOLSCAN_API_KEY=your_solscan_api_key

VITE_TWITCH_CLIENT_ID=your_twitch_client_id
VITE_X_CLIENT_ID=your_x_oauth2_client_id
X_CLIENT_ID=your_x_oauth2_client_id
X_CLIENT_SECRET=your_x_oauth2_client_secret
