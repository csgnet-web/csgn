VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase App Check (reCAPTCHA v3). Leave unset to disable App Check locally.
# Site key: Firebase console > App Check > register web app.
VITE_FIREBASE_APPCHECK_SITE_KEY=your_recaptcha_v3_site_key
# Optional: a debug token registered in the console, for local dev / CI once
# App Check enforcement is enabled.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=

VITE_TWITCH_CLIENT_ID=your_twitch_client_id
VITE_X_CLIENT_ID=your_x_oauth2_client_id
X_CLIENT_ID=your_x_oauth2_client_id
X_CLIENT_SECRET=your_x_oauth2_client_secret
